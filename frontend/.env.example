# Existing backend base URL
REACT_APP_BACKEND_URL=https://your-backend.example.com

# Optional frontend hinting for wallet/storage modes
REACT_APP_ENABLE_LACE=true
REACT_APP_STORAGE_PROVIDER=s3

# Backend should provide these endpoints for live mode:
# GET  /api/auth/wallet/nonce?role={role}&walletAddress={walletAddress}
# POST /api/auth/wallet/verify { role, walletAddress, networkId, nonce, signature }
# POST /api/storage/presign-upload { fileName, fileType, scope }
