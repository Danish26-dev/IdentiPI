PORT=8080
# Comma-separated list of allowed frontend origins
FRONTEND_ORIGIN=http://localhost:3000,https://your-app.vercel.app

# S3 live mode (optional for now)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=

# Wallet auth nonce (seconds)
WALLET_NONCE_TTL_SECONDS=300

# Midnight ZKP adapter mode: mock | sdk
MIDNIGHT_ZKP_MODE=mock
MIDNIGHT_NETWORK=testnet
MIDNIGHT_PROVING_KEY_PATH=../midnight-zkp/contracts/managed/age-over-18/keys/proving.key
MIDNIGHT_VERIFYING_KEY_PATH=../midnight-zkp/contracts/managed/age-over-18/keys/verifying.key

# Optional per-proof overrides (recommended for multi-proof workflows)
MIDNIGHT_AGE_PROVING_KEY_PATH=../midnight-zkp/contracts/managed/age-over-18/keys/proving.key
MIDNIGHT_AGE_VERIFYING_KEY_PATH=../midnight-zkp/contracts/managed/age-over-18/keys/verifying.key
MIDNIGHT_DEGREE_PROVING_KEY_PATH=../midnight-zkp/contracts/managed/degree-verification/keys/proving.key
MIDNIGHT_DEGREE_VERIFYING_KEY_PATH=../midnight-zkp/contracts/managed/degree-verification/keys/verifying.key
MIDNIGHT_ADDRESS_PROVING_KEY_PATH=../midnight-zkp/contracts/managed/address-verification/keys/proving.key
MIDNIGHT_ADDRESS_VERIFYING_KEY_PATH=../midnight-zkp/contracts/managed/address-verification/keys/verifying.key
