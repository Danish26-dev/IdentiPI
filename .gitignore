# Monorepo ignore rules

# Dependencies
**/node_modules/

# Build outputs
frontend/build/
frontend/.cache/
backend/dist/
backend/build/
midnight-zkp/build/
midnight-zkp/dist/

# Env files (keep examples committed)
backend/.env
frontend/.env
*.env.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Temporary files
*.tmp
*.swp
*.crswap
